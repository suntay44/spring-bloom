# App
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Supabase (SpringBloom platform)
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Supabase Management API (for provisioning user sub-projects)
SUPABASE_MANAGEMENT_TOKEN=sbp_...
SUPABASE_ORG_ID=org_...

# Fly.io
FLY_API_TOKEN=FlyV1...
FLY_APP_NAME=springbloom-builder
FLY_ORG=personal

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional)
OPENAI_API_KEY=sk-...

# Google (optional)
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Stripe (live)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_ID=price_...
STRIPE_PRICE_PRO_ID=price_...
STRIPE_PRICE_TEAMS_ID=price_...

# Stripe (sandbox / Connect — for user project provisioning)
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# Webhook auth
WEBHOOK_SECRET=whsec_...

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=https://...upstash.io
